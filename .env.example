# Maritime Risk Radar Dashboard – Environment Variables
# Copy this file to .env and fill in your keys

# ─────────────────────────────────────────────────────
# X (Twitter) API v2 – Official API
# Get yours at: https://developer.x.com/en/portal/dashboard
# Required for live post fetching. Free tier gives ~500k reads/month.
# ─────────────────────────────────────────────────────
X_BEARER_TOKEN=your_x_bearer_token_here

# ─────────────────────────────────────────────────────
# xAI Grok API Key – AI Analysis Engine
# Get yours at: https://console.x.ai/
# Powers the full dashboard intelligence analysis.
# Uses endpoint: https://api.x.ai/v1 (OpenAI-compatible)
# ─────────────────────────────────────────────────────
XAI_API_KEY=your_xai_api_key_here

# ─────────────────────────────────────────────────────
# TwitterAPI.io Key – Optional Cheap Fallback
# Get yours at: https://twitterapi.io/
# ~$5-10/month for basic tier. Use if you don't have official X API access.
# ─────────────────────────────────────────────────────
TWITTERIO_KEY=your_twitterio_key_here
